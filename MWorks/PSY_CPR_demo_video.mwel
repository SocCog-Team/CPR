stimulus/rectangle cum_rew_bar_frame (
    x_size                                  = (CTRL_feedback_bar_width*CTRL_feedback_nBar) + (CTRL_feedback_frame_width*CTRL_feedback_nBar)
    y_size                                  = CTRL_feedback_frame_height + CTRL_feedback_frame_width
    x_position                              = 0
    y_position                              = 0
    color                                   = 1,1,1
    rotation                                = 0
    alpha_multiplier                        = 1
    )

