group RDP {
    var RDP_direction                       = 0 {
        if (TRIAL_start > TRIAL_end) {
    		// Restrict to circular space [0:359]
    		TMP_RDPdir 					    = (RDP_direction + 360) % 360
        }
    }
    var RDP_radius                          = 8
    var RDP_y                               = 0
    var RDP_x                               = 0
    var RDP_density                         = 1
    var RDP_dotsize                         = .3
    var RDP_speed                           = 8
    var RDP_coherence                       = 0
    var RDP_lifetime                        = (1/120) * 60 * 1000 // 25 frames - 208ms
    var RDP_alpha                        	= 1
    var RDP_seed                            = 1
}

