    y_position                              = (CTRL_feedback2_bar_height/2) - (CTRL_feedback_frame_height/2)
    color                                   = COL_feedback2_r,COL_feedback2_g,COL_feedback2_b
    rotation                                = 0
    alpha_multiplier                        = 1
    )


//
// Protocols
//


protocol 'CPR_solo' {
    report ('Hello! Starting Experiment...')
    start_device_io (joystick)
    live_queue_stimulus (Background)
    update_stimulus_display ()

    // Set desired parameters
    ML_sync                                     = 1
    CTRL_NoTargets                              = 600
    CTRL_NoStates                               = 30
    CTRL_NoCoherenceStates                      = 10
    CTRL_state_min_ms                           = 1250 
    CTRL_state_max_ms                           = 2500
    CTRL_cpr_treshold                           = .2
    CTRL_arc_alpha                              = 1
    CTRL_arc_size                               = 4
    CTRL_arcMask_size                           = CTRL_arc_size - (CTRL_arc_size/7)
    CTRL_indicator_offset                       = CTRL_arc_size/1.95    
    CTRL_indicator_size                         = 1.3
    CTRL_indicator_alpha                        = 1
    CTRL_start_area_size                        = 4 
    CTRL_start_area_alpha                       = 1
    CTRL_target_size                            = 1
    CTRL_target_offset                          = 2.5
    CTRL_target_deg                             = 2 * (asin( (CTRL_target_size/2) / ((CTRL_start_area_size/2) + (CTRL_target_size/2)) ) * (180/pi))
    CTRL_target_duration_ms                 	= 50
    CTRL_target_ITI_ms                          = 500
    CTRL_target_ban_duration_ms                 = 1
	CTRL_target_alpha                   		= 1
    CTRL_fixationWidth_dva                      = CTRL_start_area_size+2
    CTRL_feedback_alpha                         = 1 
    CTRL_feedback_ms                            = 150
    CTRL_ITI_ms                                 = 2000
    CTRL_scoreBar_width                         = 0
    CTRL_show_agent                             = false
    CTRL_feedback_bar_width                     = 2
    CTRL_feedback_offset_x                      = 1
    CTRL_feedback_frame_width                   = .2
    CTRL_feedback_frame_height                  = 10
    CTRL_feedback_bar_height                    = 0
    CTRL_feedback_nBar                          = 2
    
    COL_player1_r                               = .6275 // Player1 - purple: RGB [0.6275 0.1255 0.9412]
    COL_player1_g                               = .1255
    COL_player1_b                               = .9412
    COL_arc_r                                   = COL_player1_r
    COL_arc_g                                   = COL_player1_g
    COL_arc_b                                   = COL_player1_b
    COL_feedback_r                              = COL_player1_r
    COL_feedback_g                              = COL_player1_g
    COL_feedback_b                              = COL_player1_b
    COL_scoreBar_r                              = COL_player1_r
    COL_scoreBar_g                              = COL_player1_g
    COL_scoreBar_b                              = COL_player1_b

    // Reset counters
    TRIAL_start                                 = 0
    TRIAL_end                                   = 0
    INFO_StateCounter                           = 0
    INFO_CoherenceStateCounter                  = 0
    INFO_TargetCounter                          = 0
    INFO_TrialTargetCounter                     = 0
    INFO_HitCounter                             = 0
    INFO_ErrorCounter                           = 0
    INFO_Score                                  = 0
    INFO_TrialScore                             = 0

    // Set TMP variables for online processing
    TMP_NoStates                                = CTRL_NoStates
    TMP_NoCoherenceStates                       = CTRL_NoCoherenceStates
    TMP_state_min_ms                            = CTRL_state_min_ms
    TMP_state_max_ms                            = CTRL_state_max_ms
    TMP_snr_list                                = CTRL_snr_list
    TMP_directionChange_list                    = CTRL_directionChange_list
    TMP_target_ITI_ms                           = CTRL_target_ITI_ms
    TMP_target_ban_duration_ms                  = CTRL_target_ban_duration_ms
    TMP_show_agent                              = CTRL_show_agent
    ML_sync                                     = 0

    // Initialise timer
    start_timer (
        timer                                   = TargetDurationTimer
        duration                                = 1
        duration_units                          = ms
    )

    start_timer (
        timer                                   = Target_ITI_Timer
        duration                                = 1
        duration_units                          = ms
    )

    start_timer (
        timer                                   = FeedbackTimer
        duration                                = 1
        duration_units                          = ms
    )


    cancelTrigger                               = false
    schedule (
        delay                                   = 0 
        duration                                = 10000
        repeats                                 = -999
        cancel                                  = cancelTrigger
        ) {
            IO_joystickTrigger                  = true
    }

    trial 'Trial Structure' {
        task LOOP {

            state 'Wait for Joystick Reset' {
                goto (
                    target                      = 'Wait for Joystick Movement'
                    when                        = (IO_joystickStrength <= CTRL_cpr_treshold) 
                    )
            }
            
            state 'Wait for Joystick Movement' {
                live_queue_stimulus (start_area)
                dequeue_stimulus (cum_rew_bar_frame)
                dequeue_stimulus (cum_rew_bar_surface)
                dequeue_stimulus (cum_rew_bar_solo)
                dequeue_stimulus (cum_target_counter_solo)
                update_stimulus_display ()

            	COL_start_area_r 				= 1
				COL_start_area_g 				= 1
				COL_start_area_b 				= 1
				
                goto (
                    target                      = 'New Trial'
                    when                        = (IO_joystickStrength > CTRL_cpr_treshold) 
                    )
            }

            state 'New Trial' { 
                ML_sync                         = 1 // Matlab sync event
                TRIAL_start                    += 1 // Count trial number
                TRIAL_align                     = 1 // Trial align event
                INFO_task                       = "CPR_solo_stepfunction_neutral"
                TMP_sample_counter              = 0 // Reset variables
                INFO_StateCounter               = 0 
                INFO_CoherenceStateCounter      = 0  
                INFO_TrialTargetCounter         = 0
                INFO_TrialScore                 = 0
                CTRL_scoreBar_width             = 0
                COL_start_area_r                = 0 
                COL_start_area_g                = 0
                COL_start_area_b                = 0
                CTRL_feedback_rotation          = disc_rand(0,359)

                if (TRIAL_start == 1) {
                    RDP_coherence               = .99 // Stimulus coherence of state
                }

                if (TRIAL_start > 1) {
                    RDP_coherence               = RDP_coherence - .1 // Stimulus coherence of state
                }

                if (RDP_coherence <= .1) {
                    RDP_coherence               = .1 // Stimulus coherence of state
                }
                
                // Set TMP variables for online processing
                TMP_NoStates                    = CTRL_NoStates
                TMP_NoCoherenceStates           = CTRL_NoCoherenceStates
                TMP_state_min_ms                = CTRL_state_min_ms
                TMP_state_max_ms                = CTRL_state_max_ms
                TMP_snr_list                    = CTRL_snr_list
                TMP_directionChange_list        = CTRL_directionChange_list
                TMP_target_ITI_ms               = CTRL_target_ITI_ms
                TMP_target_ban_duration_ms      = CTRL_target_ban_duration_ms
                TMP_show_agent                  = CTRL_show_agent
                ML_sync                         = 0 // Stop sync

                report ('===== TRIAL $TRIAL_start STARTS =====')
                goto ('Show Stimuli')
            }

            state 'Show Stimuli' {
                //live_queue_stimulus (scoreBarBackground)
                //live_queue_stimulus (scoreBar)
                //live_queue_stimulus (scoreBarMask)
                live_queue_stimulus (RDP)
                live_queue_stimulus (start_area)
                live_queue_stimulus (arc)
                live_queue_stimulus (arcMask)
                live_queue_stimulus (indicator)
                live_queue_stimulus (fixationCross)
                update_stimulus_display ()

                goto ('Dequeue Target')
            }

            state 'Dequeue Target' {
                //Remove target from screen
                dequeue_stimulus (target)
                update_stimulus_display ()
                
                // Reset flag
                TRIAL_reactionTrigger           = 0
                CTRL_hit_flag                   = 0
                CTRL_miss_flag                  = 0

                goto ('Check Counters')
            }

            state 'Dequeue Feedback' {
                //Remove feedback from screen
                dequeue_stimulus (feedback)
                update_stimulus_display ()

                // Reset flag
                CTRL_feedback_flag              = 0

                goto ('Check Counters')
            }

            state 'Check Counters' {
                goto (
                    target                      = 'End Trial'
                    when                        = ((INFO_StateCounter >= CTRL_NoStates) && timer_expired(StateDurationTimer)) || (INFO_TargetCounter >= CTRL_NoTargets)
                    )
                goto (
                    target                      = 'Update Stimuli'
                    when                        =  timer_expired(StateDurationTimer) == 0
                    )
                goto (
                    target                      = 'Set up state'
                    when                        =  timer_expired(StateDurationTimer) 
                    )
            }

            state 'Set up state' {
                // Determine state parameters
                CTRL_state_duration_ms          = disc_rand(1500,2500) // Duration of state
                RDP_direction                   = disc_rand(0,359)  // Stimulus direction of state
                INFO_StateCounter               += 1
                
                // Keep track of number of states with same coherence level
                if (INFO_CoherenceStateCounter >= CTRL_NoCoherenceStates) {
                    INFO_CoherenceStateCounter  = 0
                }
                INFO_CoherenceStateCounter      = INFO_CoherenceStateCounter + 1
                TRIAL_type                      = format("Coh%d", (float)RDP_coherence)

                start_timer (
                    timer                       = StateDurationTimer
                    duration                    = CTRL_state_duration_ms
                    duration_units              = ms
                    )

                // Block target appearance in time window after state onset
                start_timer (
                    timer                       = TargetBanTimer
                    duration                    = CTRL_target_ban_duration_ms
                    duration_units              = ms
                    )

                report ('--- State $INFO_StateCounter ---')
                goto ('Update Stimuli')
            }


			state 'Update Stimuli' { 
                goto (                    
                    target                      = 'Fixation break detected'
                    when                        = (IO_fixation_flag == 0 && CTRL_fixation_break_flag == 0) 
                    )
                goto (                    
                    target                      = 'Reset CTRL_fixation_break_flag'
                    when                        = (IO_fixation_flag && CTRL_fixation_break_flag && timer_expired(MinFixationBreakTimer) == 0) 
                    )                
                goto (                    
                    target                      = 'Fixation break penalty'
                    when                        = (IO_fixation_flag == 0 && timer_expired(MinFixationBreakTimer) && CTRL_fixation_break_flag && CTRL_fixation_penalty_flag == 0)
                    )
                goto (                    
                    target                      = 'Fixation restored'
                    when                        = (IO_fixation_flag && timer_expired(FixBreakPenaltyTimer) && CTRL_fixation_break_flag) 
                    )
                goto (
                    target                      = 'Dequeue Target'
                    when                        = CTRL_hit_flag && TRIAL_reactionTrigger && timer_expired(TargetDurationTimer)
                    )
                goto (
                    target                      = 'Dequeue Feedback'
                    when                        = CTRL_feedback_flag && timer_expired(TargetDurationTimer) && timer_expired(FeedbackTimer) 
                    )
                goto (
                    target                      = 'Target presentation'
                    when                        = CTRL_target_idx == 0 && TRIAL_reactionTrigger == 0 && timer_expired(Target_ITI_Timer) && timer_expired(TargetBanTimer)
                    ) 
                goto (
                    target                      = 'Hit'
                    when                        = CTRL_arc_flag && TRIAL_reactionTrigger && (CTRL_hit_flag + CTRL_miss_flag) == 0 && timer_expired(TargetDurationTimer) == 0 && CTRL_fixation_penalty_flag == 0
                    )  
                goto (
                    target                      = 'Miss'
                    when                        = timer_expired(TargetDurationTimer) && TRIAL_reactionTrigger && (CTRL_hit_flag + CTRL_miss_flag) == 0
                    )              
                goto (
                    target                      = 'Check Counters'
                    when                        = timer_expired(StateDurationTimer) && TRIAL_reactionTrigger == 0
                    )
            }
           
            state 'Fixation break detected' {
                CTRL_fixation_break_flag        = 1

                start_timer (
                    timer                       = MinFixationBreakTimer
                    duration                    = CTRL_minFixBreak_duration_ms
                    duration_units              = ms
                    )
                    
                //report ('FIX BREAK')
                
                goto ('Update Stimuli')
            }

            state 'Reset CTRL_fixation_break_flag' {
                    CTRL_fixation_break_flag        = 0
                    //report ('FIX RESET')
                    goto ('Update Stimuli')
            }

            state 'Fixation break penalty' {
                CTRL_fixation_size              = .75
                COL_fix_r                       = 1
                COL_fix_b                       = 0
                COL_fix_g                       = 0
                CTRL_arc_alpha                  = 0
                CTRL_indicator_alpha            = 0
                CTRL_fixation_penalty_flag 		= 1

                start_timer (
                    timer                       = FixBreakPenaltyTimer
                    duration                    = CTRL_fixBreak_penalty_duration_ms
                    duration_units              = ms
                    )
                
                report ('FIX PENALTY')
                
                goto ('Update Stimuli')
            }

            state 'Fixation restored' {
                CTRL_fixation_size              = .3
                COL_fix_r                       = 1
                COL_fix_b                       = 1
                COL_fix_g                       = 1
                CTRL_arc_alpha                  = 1
                CTRL_indicator_alpha            = 1
                CTRL_fixation_break_flag        = 0
                CTRL_fixation_penalty_flag 		= 0

                report ('FIX RESTORED')

                goto ('Update Stimuli')
            }

       		state 'Target presentation' {
                // Target coordinates according to RDP direction
                CTRL_target_x                   = (sin((RDP_direction)*(pi/180)) * (CTRL_target_offset)) + RDP_x
                CTRL_target_y                   = (cos((RDP_direction)*(pi/180)) * (CTRL_target_offset)) + RDP_x

                live_queue_stimulus (target)
                update_stimulus_display ()

                TRIAL_reactionTrigger           = 1
                INFO_TargetCounter              += 1
                INFO_TrialTargetCounter         += 1

                start_timer (
                    timer                       = TargetDurationTimer
                    duration                    = CTRL_target_duration_ms
                    duration_units              = ms
                    )

                // Block target appearance
                start_timer (
                    timer                       = Target_ITI_Timer
                    duration                    = (CTRL_target_duration_ms + CTRL_target_ITI_ms)
                    duration_units              = ms
                    )

                report ('--- SHOW TARGET $INFO_TargetCounter ---')
                goto ('Update Stimuli')
            }

            state 'Hit' {
            	// Set flags and add to counters
                TRIAL_outcome                   = "hit"
                CTRL_hit_flag                   = 1
                CTRL_feedback_flag              = 1
                INFO_HitCounter                 += 1
                INFO_Score                      += TMP_score
                INFO_TrialScore                 += TMP_score
                CTRL_scoreBar_width             = 360 * (INFO_TrialScore/INFO_TrialTargetCounter)

                // PRESENT BOTH SPEAKERS - SETUP INDEPENDENT
                if (TMP_score > .875) {
                    play_sound (Reward8R_sound)
                    play_sound (Reward8L_sound)
                }

                if (TMP_score > .75 && TMP_score <= .875) {
                    play_sound (Reward7R_sound)
                    play_sound (Reward7L_sound)
                }

                if (TMP_score > .625 && TMP_score <= .75) {
                    play_sound (Reward6R_sound)
                    play_sound (Reward6L_sound)
                }

                if (TMP_score > .5 && TMP_score <= .625) {
                    play_sound (Reward5R_sound)
                    play_sound (Reward5L_sound)
                }

                if (TMP_score > .375 && TMP_score <= .5) {
                    play_sound (Reward4R_sound)
                    play_sound (Reward4L_sound)
                }

                if (TMP_score > .25 && TMP_score <= .375) {
                    play_sound (Reward3R_sound)
                    play_sound (Reward3L_sound)
                }

                if (TMP_score > .125 && TMP_score <= .25) {
                    play_sound (Reward2R_sound)
                    play_sound (Reward2L_sound)
                }

                if (TMP_score <= .125) {
                    play_sound (Reward1R_sound)
                    play_sound (Reward1L_sound)
                }

				// Visual feedback
				live_queue_stimulus (feedback)
				live_queue_stimulus (fixationCross)
                update_stimulus_display ()

                report ('--- OUTCOME: Hit ---')
                report ('Score: $TMP_score')

                start_timer (
                    timer                       = FeedbackTimer
                    duration                    = CTRL_feedback_ms
                    duration_units              = ms
                    )

                goto ('Update Stimuli')
            }
    
            state 'Miss' {
                //play_sound (Failure_sound)

                // Set flags
                TRIAL_outcome                   = "miss"
                CTRL_miss_flag                  = 1
                INFO_ErrorCounter               += 1
                CTRL_scoreBar_width             = 360 * (INFO_TrialScore/INFO_TrialTargetCounter)

                report ('--- OUTCOME: Miss ---')

                goto (
                    target                      = 'End Trial'
                    when                        = ((INFO_StateCounter >= CTRL_NoStates) && timer_expired(StateDurationTimer)) || (INFO_TargetCounter >= CTRL_NoTargets)
                    )
                goto ('Dequeue Target')
            }  

            state 'End Trial' {
                //dequeue_stimulus (scoreBarBackground)
                //dequeue_stimulus (scoreBar)
                //dequeue_stimulus (scoreBarMask)
                dequeue_stimulus (RDP)
                dequeue_stimulus (start_area)
                dequeue_stimulus (arc)
                dequeue_stimulus (arcMask)
                dequeue_stimulus (indicator)
                dequeue_stimulus (fixationCross)
                dequeue_stimulus (target)
                dequeue_stimulus (feedback)


                TRIAL_align                     = 0
                TRIAL_end                     	= TRIAL_start

                start_timer (
                    timer                       = ITI_Timer
                    duration                    = CTRL_ITI_ms
                    duration_units              = ms
                    )

                update_stimulus_display ()
                report ('===== TRIAL $TRIAL_end ENDS =====')
                goto (ITI)
            }

            state ITI {
                CTRL_feedback_bar_height                = INFO_Score*(CTRL_feedback_frame_height/CTRL_NoTargets)
                CTRL_feedback_target_bar_height         = INFO_TargetCounter*(CTRL_feedback_frame_height/CTRL_NoTargets)
                
                live_queue_stimulus (cum_rew_bar_frame)
                live_queue_stimulus (cum_rew_bar_surface)
                live_queue_stimulus (cum_rew_bar_solo)
                live_queue_stimulus (cum_target_counter_solo)
                update_stimulus_display ()   
                    
                goto (
                    target                      = 'End paradigm'
                    when                        = INFO_TargetCounter >= CTRL_NoTargets && timer_expired(ITI_Timer)
                    )
                timer_expired (
                    target                      = 'Wait for Joystick Reset'
                    timer                       = ITI_Timer
                    )
            }
            state 'End paradigm' {
                update_stimulus_display ()
                report ('==== SUMMARY: $INFO_HitCounter / $INFO_TargetCounter COINS COLLECTED ====')
                report ('==== ENDING PARADIGM ====')
                play_sound (End_sound)
                cancelTrigger                   = false
                yield ()
            }
        }
    }
}


protocol 'CPR_dyatic' {
    report ('Hello! Starting Experiment...')
    live_queue_stimulus (Background)
    start_device_io (joystick)
    start_device_io (joystick2)
    update_stimulus_display ()

   // Set desired parameters
    ML_sync                                     = 1
    CTRL_NoTargets                              = 600
    CTRL_NoStates                               = 30
    CTRL_NoCoherenceStates                      = 10 
    CTRL_state_min_ms                           = 1250 
    CTRL_state_max_ms                           = 2500
    CTRL_cpr_treshold                           = .2
    CTRL_arc_alpha                              = 1
    CTRL_arc2_alpha                             = 1
    CTRL_arc_size                               = 4
    CTRL_arc2_size                               = CTRL_arc_size + (CTRL_arc_size/10)
    CTRL_indicator_size                         = 1.3
    CTRL_indicator_offset                       = CTRL_arc_size/1.95
    CTRL_indicator_alpha                        = 1
    CTRL_indicator2_alpha                       = 1
    CTRL_indicator2_offset                      = 4.4 / 1.95
    CTRL_start_area_size                        = 4 
    CTRL_start_area_alpha                       = 1
    CTRL_target_size                            = 1
    CTRL_target_offset                          = 2.5
    CTRL_target_deg                             = 2 * (asin( (CTRL_target_size/2) / ((CTRL_start_area_size/2) + (CTRL_target_size/2)) ) * (180/pi))
    CTRL_target_duration_ms                     = 50
    CTRL_target_ITI_ms                          = 500
    CTRL_target_ban_duration_ms                 = 1
    CTRL_target_alpha                           = 1
    CTRL_fixationWidth_dva                      = CTRL_start_area_size+2
    CTRL_feedback_alpha                         = 1 
    CTRL_feedback_ms                            = 150
    CTRL_ITI_ms                                 = 2000
    CTRL_scoreBar_width                         = 0
    CTRL_show_agent                             = false
    CTRL_feedback_bar_width                     = 2
    CTRL_feedback_offset_x                      = 2
    CTRL_feedback_frame_width                   = .2
    CTRL_feedback_frame_height                  = 10
    CTRL_feedback_bar_height                    = 0
    CTRL_feedback2_bar_height                   = 0
    CTRL_feedback_nBar                          = 3

    COL_player1_r                               = .6275 // Player1 - purple: RGB [0.6275 0.1255 0.9412]
    COL_player1_g                               = .1255
    COL_player1_b                               = .9412
    COL_player2_r                               = 0 //Player2 - green: [0 .4 0]
    COL_player2_g                               = .4
    COL_player2_b                               = 0
    COL_arc_r                                   = COL_player1_r
    COL_arc_g                                   = COL_player1_g
    COL_arc_b                                   = COL_player1_b
    COL_feedback_r                              = COL_player1_r
    COL_feedback_g                              = COL_player1_g
    COL_feedback_b                              = COL_player1_b
    COL_scoreBar_r                              = COL_player1_r
    COL_scoreBar_g                              = COL_player1_g
    COL_scoreBar_b                              = COL_player1_b
    COL_arc2_r                                  = COL_player2_r
    COL_arc2_g                                  = COL_player2_g
    COL_arc2_b                                  = COL_player2_b
    COL_feedback2_r                             = COL_player2_r
    COL_feedback2_g                             = COL_player2_g
    COL_feedback2_b                             = COL_player2_b
    COL_scoreBar2_r                             = COL_player2_r
    COL_scoreBar2_g                             = COL_player2_g
    COL_scoreBar2_b                             = COL_player2_b

    // Reset counters
    TRIAL_start                                 = 0
    TRIAL_end                                   = 0
    INFO_StateCounter                           = 0
    INFO_CoherenceStateCounter                  = 0
    INFO_TargetCounter                          = 0
    INFO_TrialTargetCounter                     = 0
    INFO_HitCounter                             = 0
    INFO_ErrorCounter                           = 0
    INFO_HitCounter2                            = 0
    INFO_ErrorCounter2                          = 0
    INFO_Score                                  = 0
    INFO_Score2                                 = 0
    INFO_TrialScore                             = 0
    INFO_TrialScore2                            = 0

    // Set TMP variables for online processing
    TMP_NoStates                                = CTRL_NoStates
    TMP_NoCoherenceStates                       = CTRL_NoCoherenceStates
    TMP_state_min_ms                            = CTRL_state_min_ms
    TMP_state_max_ms                            = CTRL_state_max_ms
    TMP_snr_list                                = CTRL_snr_list
    TMP_directionChange_list                    = CTRL_directionChange_list
    TMP_target_ITI_ms                           = CTRL_target_ITI_ms
    TMP_target_ban_duration_ms                  = CTRL_target_ban_duration_ms
    ML_sync                                     = 0

    // Initialise timer
    start_timer (
        timer                                   = TargetDurationTimer
        duration                                = 1
        duration_units                          = ms
    )

    start_timer (
        timer                                   = Target_ITI_Timer
        duration                                = 1
        duration_units                          = ms
    )

    start_timer (
        timer                                   = FeedbackTimer
        duration                                = 1
        duration_units                          = ms
    )

    cancelTrigger                               = false
    schedule (
        delay                                   = 0 
        duration                                = 10000
        repeats                                 = -999
        cancel                                  = cancelTrigger
        ) {
            IO_joystickTrigger                  = true
            IO_joystickTrigger2                 = true
    }

    trial 'Trial Structure' {
        task LOOP {

            state 'Wait for Joystick Reset' {
                goto (
                    target                      = 'Wait for Joystick Movement'
                    when                        = (IO_joystickStrength <= CTRL_cpr_treshold) && (IO_joystickStrength2 <= CTRL_cpr_treshold)  
                    )
            }
            
            state 'Wait for Joystick Movement' {
                live_queue_stimulus (start_area)
                dequeue_stimulus (cum_rew_bar_frame)
                dequeue_stimulus (cum_rew_bar_surface)
                dequeue_stimulus (cum_rew_bar)
                dequeue_stimulus (cum_rew_bar2)
                dequeue_stimulus (cum_target_counter)
                update_stimulus_display ()

                COL_start_area_r                = 1
                COL_start_area_g                = 1
                COL_start_area_b                = 1
                
                goto (
                    target                      = 'New Trial'
                    when                        = (IO_joystickStrength > CTRL_cpr_treshold) && (IO_joystickStrength2 > CTRL_cpr_treshold)  
                    )
            }
            
            state 'New Trial' {
                ML_sync                         = 1 // Matlab sync event
                TRIAL_start                    += 1 // Count trial number
                TRIAL_align                     = 1 // Trial align event
                INFO_task                       = "CPR_dyadic_stepfunction_neutral"
                TMP_sample_counter              = 0 // Reset variables
                INFO_StateCounter               = 0 
                INFO_CoherenceStateCounter      = 0         
                INFO_TrialTargetCounter         = 0
                INFO_TrialScore                 = 0
                INFO_TrialScore2                = 0  
                CTRL_scoreBar_width             = 0
                CTRL_scoreBar2_width            = 0      
                COL_start_area_r                = 0 
                COL_start_area_g                = 0
                COL_start_area_b                = 0
                CTRL_feedback_rotation          = disc_rand(0,359)
                CTRL_arc_position               = TRIAL_start % 2

                // Alternate arc trajectory
                if (CTRL_arc_position == 0) {
                    CTRL_arc_size               = 4
                    CTRL_arcMask_size           = CTRL_arc_size - (CTRL_arc_size/10)
                    CTRL_indicator_offset       = CTRL_arc_size/1.95

                    CTRL_arc2_size              = CTRL_arcMask_size
                    CTRL_arcMask2_size          = CTRL_arc2_size - (CTRL_arc_size/10)
                    CTRL_indicator2_offset      = CTRL_arc2_size / 1.95
                }

                if (CTRL_arc_position == 1) {
                    CTRL_arc2_size              = 4
                    CTRL_arcMask2_size          = CTRL_arc2_size - (CTRL_arc2_size/10)
                    CTRL_indicator2_offset      = CTRL_arc2_size/1.95

                    CTRL_arc_size               = CTRL_arcMask2_size
                    CTRL_arcMask_size           = CTRL_arc_size - (CTRL_arc2_size/10)
                    CTRL_indicator_offset       = CTRL_arc_size / 1.95
                }

                if (TRIAL_start == 1) {
                    RDP_coherence               = .99 // Stimulus coherence of state
                }

                if (TRIAL_start > 1) {
                    RDP_coherence               = RDP_coherence - .1 // Stimulus coherence of state
                }

                if (RDP_coherence <= .1) {
                    RDP_coherence               = .1 // Stimulus coherence of state
                }
                     
                // Set TMP variables for online processing
                TMP_NoStates                    = CTRL_NoStates
                TMP_NoCoherenceStates           = CTRL_NoCoherenceStates
                TMP_state_min_ms                = CTRL_state_min_ms
                TMP_state_max_ms                = CTRL_state_max_ms
                TMP_snr_list                    = CTRL_snr_list
                TMP_directionChange_list        = CTRL_directionChange_list
                TMP_target_ITI_ms               = CTRL_target_ITI_ms
                TMP_target_ban_duration_ms      = CTRL_target_ban_duration_ms
                TMP_show_agent                  = CTRL_show_agent
                ML_sync                         = 0 // Stop sync

                report ('===== TRIAL $TRIAL_start STARTS =====')
                goto ('Show Stimuli')
            }

            state 'Show Stimuli' {
                //live_queue_stimulus (scoreBarBackground2)
                //live_queue_stimulus (scoreBar2)
                //live_queue_stimulus (scoreBarMask2)
                //live_queue_stimulus (scoreBarBackground)
                //live_queue_stimulus (scoreBar)
                //live_queue_stimulus (scoreBarMask)
                live_queue_stimulus (RDP)
                live_queue_stimulus (start_area)

                if (CTRL_arc_position == 1) {
                    live_queue_stimulus (arc2)
                    live_queue_stimulus (indicator2)
                    live_queue_stimulus (arcMask2)
                    live_queue_stimulus (arc)
                    live_queue_stimulus (arcMask)
                    live_queue_stimulus (indicator)
                }

                if (CTRL_arc_position == 0) {
                    live_queue_stimulus (arc)
                    live_queue_stimulus (arcMask)
                    live_queue_stimulus (indicator)
                    live_queue_stimulus (arc2)
                    live_queue_stimulus (arcMask2)
                    live_queue_stimulus (indicator2)
                }

                live_queue_stimulus (fixationCross)
                live_queue_stimulus (fixationCross2)
                update_stimulus_display () 

                goto ('Dequeue Target')
            }

            state 'Dequeue Target' {
                //Remove target from screen
                dequeue_stimulus (target)
                update_stimulus_display ()
                
                // Reset flag
                TRIAL_reactionTrigger           = 0
                CTRL_hit_flag                   = 0
                CTRL_hit_flag2                  = 0
                CTRL_miss_flag                  = 0
                CTRL_miss_flag2                 = 0

                goto ('Check Counters')
            }

            state 'Dequeue Feedback' {
                //Remove feedback from screen
                dequeue_stimulus (feedback1)
                dequeue_stimulus (feedback2)
                update_stimulus_display ()

                // Reset flag
                CTRL_feedback_flag              = 0

                goto ('Check Counters')
            }

            state 'Check Counters' {
                goto (
                    target                      = 'End Trial'
                    when                        = ((INFO_StateCounter >= CTRL_NoStates) && timer_expired(StateDurationTimer)) || (INFO_TargetCounter >= CTRL_NoTargets)
                    )
                goto (
                    target                      = 'Update Stimuli'
                    when                        =  timer_expired(StateDurationTimer) == 0
                    )
                goto (
                    target                      = 'Set up state'
                    when                        =  timer_expired(StateDurationTimer) 
                    )
            }

            state 'Set up state' {
                // Determine state parameters
                CTRL_state_duration_ms          = disc_rand(1500,2500) // Duration of state
                RDP_direction                   = disc_rand(0,359)  // Stimulus direction of state           
                INFO_StateCounter               += 1
                
                // Keep track of number of states with same coherence level
                if (INFO_CoherenceStateCounter >= CTRL_NoCoherenceStates) {
                    INFO_CoherenceStateCounter  = 0
                }
                INFO_CoherenceStateCounter      = INFO_CoherenceStateCounter + 1
                TRIAL_type                      = format("Coh%d", (float)RDP_coherence)

                start_timer (
                    timer                       = StateDurationTimer
                    duration                    = CTRL_state_duration_ms
                    duration_units              = ms
                    )

                // Block target appearance in time window after state onset
                start_timer (
                    timer                       = TargetBanTimer
                    duration                    = CTRL_target_ban_duration_ms
                    duration_units              = ms
                    )

                report ('--- State $INFO_StateCounter ---')
                goto ('Update Stimuli')
            }

            state 'Update Stimuli' {
                goto (                    
                    target                      = 'Fixation break detected'
                    when                        = (IO_fixation_flag == 0 && CTRL_fixation_break_flag == 0) || (IO_fixation2_flag == 0 && CTRL_fixation2_break_flag == 0)
                    )
                goto (                    
                    target                      = 'Reset CTRL_fixation_break_flag'
                    when                        = (IO_fixation_flag && CTRL_fixation_break_flag && timer_expired(MinFixationBreakTimer)==0) || (IO_fixation2_flag && CTRL_fixation2_break_flag && timer_expired(MinFixationBreakTimer2)==0)
                    )                
                goto (                    
                    target                      = 'Fixation break penalty'
                    when                        = (IO_fixation_flag == 0 && timer_expired(MinFixationBreakTimer) && CTRL_fixation_break_flag && CTRL_fixation_penalty_flag==0) || (IO_fixation2_flag == 0 && timer_expired(MinFixationBreakTimer2) && CTRL_fixation2_break_flag && CTRL_fixation2_penalty_flag==0)
                    )
                goto (                    
                    target                      = 'Fixation restored'
                    when                        = (IO_fixation_flag && timer_expired(FixBreakPenaltyTimer) && CTRL_fixation_break_flag) || (IO_fixation2_flag && timer_expired(FixBreakPenaltyTimer2) && CTRL_fixation2_break_flag)
                    )
                goto (
                    target                      = 'Dequeue Target'
                    when                        = (CTRL_hit_flag + CTRL_hit_flag2) > 0 && TRIAL_reactionTrigger && timer_expired(TargetDurationTimer)
                    )
                goto (
                    target                      = 'Dequeue Feedback'
                    when                        = CTRL_feedback_flag && timer_expired(TargetDurationTimer) && timer_expired(FeedbackTimer) 
                    )
                goto (
                    target                      = 'Target presentation'
                    when                        = CTRL_target_idx == 0 && TRIAL_reactionTrigger == 0 && timer_expired(Target_ITI_Timer) && timer_expired(TargetBanTimer)
                    ) 
                goto (
                    target                      = 'Single Hit A'
                    when                        = (CTRL_arc_flag && CTRL_fixation_penalty_flag == 0) && (CTRL_arc2_flag == 0 || CTRL_fixation2_penalty_flag == 1) && TRIAL_reactionTrigger && (CTRL_hit_flag + CTRL_hit_flag2 + CTRL_miss_flag + CTRL_miss_flag2) == 0 && timer_expired(TargetDurationTimer) == 0 
                    ) 
                goto (
                    target                      = 'Single Hit B'
                    when                        = (CTRL_arc_flag == 0 || CTRL_fixation_penalty_flag == 1) && (CTRL_arc2_flag && CTRL_fixation2_penalty_flag == 0) && TRIAL_reactionTrigger && (CTRL_hit_flag + CTRL_hit_flag2 + CTRL_miss_flag + CTRL_miss_flag2) == 0 && timer_expired(TargetDurationTimer) == 0 
                    )
                goto (
                    target                      = 'DoubleHit'
                    when                        = (CTRL_arc_flag && CTRL_fixation_penalty_flag == 0) && (CTRL_arc2_flag && CTRL_fixation2_penalty_flag == 0) && TRIAL_reactionTrigger && (CTRL_hit_flag + CTRL_hit_flag2 + CTRL_miss_flag + CTRL_miss_flag2) == 0 && timer_expired(TargetDurationTimer) == 0
                    )  
                goto (
                    target                      = 'DoubleMiss'
                    when                        = timer_expired(TargetDurationTimer) && TRIAL_reactionTrigger && (CTRL_hit_flag + CTRL_hit_flag2 + CTRL_miss_flag + CTRL_miss_flag2) == 0 
                    )              
                goto (
                    target                      = 'Check Counters'
                    when                        = timer_expired(StateDurationTimer) && TRIAL_reactionTrigger == 0
                    )
            }

            state 'Fixation break detected' {

                if (IO_fixation_flag == 0 && CTRL_fixation_break_flag == 0) {
                    //report ('FIX BREAK A')
                    CTRL_fixation_break_flag      = 1

                    start_timer (
                        timer                       = MinFixationBreakTimer
                        duration                    = CTRL_minFixBreak_duration_ms
                        duration_units              = ms
                        )  
                }

                if (IO_fixation2_flag == 0 && CTRL_fixation2_break_flag == 0) {
                    //report ('FIX BREAK B')
                    CTRL_fixation2_break_flag       = 1

                    start_timer (
                        timer                       = MinFixationBreakTimer2
                        duration                    = CTRL_minFixBreak_duration_ms
                        duration_units              = ms
                        )  
                }

                goto ('Update Stimuli')
            }

            state 'Reset CTRL_fixation_break_flag' {
                if (IO_fixation_flag && CTRL_fixation_break_flag && timer_expired(MinFixationBreakTimer)) {
                    //report ('FIX BREAK RESET A')
                    CTRL_fixation_break_flag        = 0
                }

                if (IO_fixation2_flag && CTRL_fixation2_break_flag && timer_expired(MinFixationBreakTimer2)) {
                    //report ('FIX BREAK RESET B')
                    CTRL_fixation2_break_flag       = 0
                }
            
                goto ('Update Stimuli')

            }

            state 'Fixation break penalty' {

                if (IO_fixation_flag == 0 && CTRL_fixation_break_flag) {
                    report ('FIX BREAK PENALTY A')
                    CTRL_arc_alpha                  = 0
                    CTRL_indicator_alpha            = 0
                    CTRL_fixation_penalty_flag      = 1

                    start_timer (
                        timer                       = FixBreakPenaltyTimer
                        duration                    = CTRL_fixBreak_penalty_duration_ms
                        duration_units              = ms
                        )  
                }

                if (IO_fixation2_flag == 0 && CTRL_fixation2_break_flag) {
                    report ('FIX BREAK PENALTY B')
                    CTRL_arc2_alpha                 = 0
                    CTRL_indicator2_alpha           = 0
                    CTRL_fixation2_penalty_flag     = 1

                    start_timer (
                        timer                       = FixBreakPenaltyTimer2
                        duration                    = CTRL_fixBreak_penalty_duration_ms
                        duration_units              = ms
                        )  
                }

                goto ('Update Stimuli')
            }

            state 'Fixation restored' {

                if (IO_fixation_flag && timer_expired(FixBreakPenaltyTimer) && CTRL_fixation_break_flag) {
                    report ('FIX RESTORED A')
                    CTRL_arc_alpha                  = 1
                    CTRL_indicator_alpha            = 1
                    CTRL_fixation_break_flag        = 0
                    CTRL_fixation_penalty_flag      = 0
                }

                if (IO_fixation2_flag && timer_expired(FixBreakPenaltyTimer2) && CTRL_fixation2_break_flag) {
                    report ('FIX RESTORED B')
                    CTRL_arc2_alpha                 = 1
                    CTRL_indicator2_alpha           = 1
                    CTRL_fixation2_break_flag       = 0
                    CTRL_fixation2_penalty_flag     = 0
                }

                goto ('Update Stimuli')
            }

            state 'Target presentation' {
                // Target coordinates according to RDP direction
                CTRL_target_x                   = (sin((RDP_direction)*(pi/180)) * (CTRL_target_offset)) + RDP_x
                CTRL_target_y                   = (cos((RDP_direction)*(pi/180)) * (CTRL_target_offset)) + RDP_x
                
                live_queue_stimulus (target)
                update_stimulus_display ()

                TRIAL_reactionTrigger           = 1
                INFO_TargetCounter              += 1
                INFO_TrialTargetCounter         += 1

                start_timer (
                    timer                       = TargetDurationTimer
                    duration                    = CTRL_target_duration_ms
                    duration_units              = ms
                    )

                // Block target appearance
                start_timer (
                    timer                       = Target_ITI_Timer
                    duration                    = (CTRL_target_duration_ms + CTRL_target_ITI_ms)
                    duration_units              = ms
                    )

                report ('--- SHOW TARGET $INFO_TargetCounter ---')
                goto ('Update Stimuli')
            }

            state 'Single Hit A' {
                // Set flags and add to counters
                TRIAL_outcome                   = "hit"
                CTRL_hit_flag                   = 1
                INFO_HitCounter                 += 1
                INFO_Score                      += TMP_score
                INFO_TrialScore                 += TMP_score
                CTRL_scoreBar_width             = 360 * (INFO_TrialScore/INFO_TrialTargetCounter)

                TRIAL_outcome2                  = "miss"
                CTRL_hit_flag2                  = 0
                CTRL_scoreBar2_width            = 360 * (INFO_TrialScore2/INFO_TrialTargetCounter)

                CTRL_feedback_flag              = 1

                // PRESENT AT SPEAKER R ONLY
                if (TMP_score > .875) {
                    play_sound (Reward8R_sound)
                }

                if (TMP_score > .75 && TMP_score <= .875) {
                    play_sound (Reward7R_sound)
                }

                if (TMP_score > .625 && TMP_score <= .75) {
                    play_sound (Reward6R_sound)
                }

                if (TMP_score > .5 && TMP_score <= .625) {
                    play_sound (Reward5R_sound)
                }

                if (TMP_score > .375 && TMP_score <= .5) {
                    play_sound (Reward4R_sound)
                }

                if (TMP_score > .25 && TMP_score <= .375) {
                    play_sound (Reward3R_sound)
                }

                if (TMP_score > .125 && TMP_score <= .25) {
                    play_sound (Reward2R_sound)
                }

                if (TMP_score <= .125) {
                    play_sound (Reward1R_sound)
                }

                //Visual feedback
                live_queue_stimulus (feedback1)
                live_queue_stimulus (fixationCross)
                live_queue_stimulus (fixationCross2)
                update_stimulus_display ()

                report ('--- OUTCOME: Single Hit A ---')
                report ('Score_A: $TMP_score')

                goto ('Start Feedback Timer')
            }

            state 'Single Hit B' {
                // Set flags and add to counters
                TRIAL_outcome                   = "miss"
                CTRL_hit_flag                   = 0
                CTRL_scoreBar_width            = 360 * (INFO_TrialScore/INFO_TrialTargetCounter)

                TRIAL_outcome2                  = "hit"
                CTRL_hit_flag2                  = 1
                INFO_HitCounter2                += + 1
                INFO_Score2                     += TMP_score2
                INFO_TrialScore2                += TMP_score2
                CTRL_scoreBar2_width            = 360 * (INFO_TrialScore2/INFO_TrialTargetCounter)

                CTRL_feedback_flag              = 1

                // PRESENT AT SPEAKER L ONLY
                if (TMP_score2 > .875) {
                    play_sound (Reward8L_sound)
                }

                if (TMP_score2 > .75 && TMP_score2 <= .875) {
                    play_sound (Reward7L_sound)
                }

                if (TMP_score2 > .625 && TMP_score2 <= .75) {
                    play_sound (Reward6L_sound)
                }

                if (TMP_score2 > .5 && TMP_score2 <= .625) {
                    play_sound (Reward5L_sound)
                }

                if (TMP_score2 > .375 && TMP_score2 <= .5) {
                    play_sound (Reward4L_sound)
                }

                if (TMP_score2 > .25 && TMP_score2 <= .375) {
                    play_sound (Reward3L_sound)
                }

                if (TMP_score2 > .125 && TMP_score2 <= .25) {
                    play_sound (Reward2L_sound)
                }

                if (TMP_score2 <= .125) {
                    play_sound (Reward1L_sound)
                }

                //Visual feedback
                live_queue_stimulus (feedback2)
                live_queue_stimulus (fixationCross)
                live_queue_stimulus (fixationCross2)
                update_stimulus_display ()

                report ('--- OUTCOME: Single Hit B ---')
                report ('Score_B: $TMP_score2')

                goto ('Start Feedback Timer')
            }

            state 'DoubleHit' {
                // Set flags and add to counters
                TRIAL_outcome                   = "hit"
                CTRL_hit_flag                   = 1
                INFO_HitCounter                 += 1
                INFO_Score                      += TMP_score
                INFO_TrialScore                 += TMP_score
                CTRL_scoreBar_width             = 360 * (INFO_TrialScore/INFO_TrialTargetCounter)

                TRIAL_outcome2                  = "hit"
                CTRL_hit_flag2                  = 1
                INFO_HitCounter2                += 1
                INFO_Score2                     += TMP_score2
                INFO_TrialScore2                += TMP_score2
                CTRL_scoreBar2_width            = 360 * (INFO_TrialScore2/INFO_TrialTargetCounter)

                CTRL_feedback_flag              = 1

                // PRESENT AT SPEAKER R ONLY
                if (TMP_score > .875) {
                    play_sound (Reward8R_sound)
                }

                if (TMP_score > .75 && TMP_score <= .875) {
                    play_sound (Reward7R_sound)
                }

                if (TMP_score > .625 && TMP_score <= .75) {
                    play_sound (Reward6R_sound)
                }

                if (TMP_score > .5 && TMP_score <= .625) {
                    play_sound (Reward5R_sound)
                }

                if (TMP_score > .375 && TMP_score <= .5) {
                    play_sound (Reward4R_sound)
                }

                if (TMP_score > .25 && TMP_score <= .375) {
                    play_sound (Reward3R_sound)
                }

                if (TMP_score > .125 && TMP_score <= .25) {
                    play_sound (Reward2R_sound)
                }

                if (TMP_score <= .125) {
                    play_sound (Reward1R_sound)
                }

                // PRESENT AT SPEAKER L ONLY
                if (TMP_score2 > .875) {
                    play_sound (Reward8L_sound)
                }

                if (TMP_score2 > .75 && TMP_score2 <= .875) {
                    play_sound (Reward7L_sound)
                }

                if (TMP_score2 > .625 && TMP_score2 <= .75) {
                    play_sound (Reward6L_sound)
                }

                if (TMP_score2 > .5 && TMP_score2 <= .625) {
                    play_sound (Reward5L_sound)
                }

                if (TMP_score2 > .375 && TMP_score2 <= .5) {
                    play_sound (Reward4L_sound)
                }

                if (TMP_score2 > .25 && TMP_score2 <= .375) {
                    play_sound (Reward3L_sound)
                }

                if (TMP_score2 > .125 && TMP_score2 <= .25) {
                    play_sound (Reward2L_sound)
                }

                if (TMP_score2 <= .125) {
                    play_sound (Reward1L_sound)
                }

                //Visual feedback
                live_queue_stimulus (feedback1)
                live_queue_stimulus (feedback2)
                live_queue_stimulus (fixationCross)
                live_queue_stimulus (fixationCross2)
                update_stimulus_display ()
                
                report ('--- OUTCOME: Double Hit ---')
                report ('Scofre_A: $TMP_score || Score_B: $TMP_score2')

                goto ('Start Feedback Timer')
            }  
                 
            state 'Start Feedback Timer'{
                start_timer (
                    timer                       = FeedbackTimer
                    duration                    = CTRL_feedback_ms
                    duration_units              = ms
                    )
                goto ('Update Stimuli')
            }

            state 'DoubleMiss' {
                //play_sound (Failure_sound)

                // Set flags
                TRIAL_outcome                   = "miss"
                CTRL_hit_flag                   = 0
                TRIAL_outcome2                  = "miss"
                CTRL_hit_flag2                  = 0

                CTRL_scoreBar_width             = 360 * (INFO_TrialScore/INFO_TrialTargetCounter)
                CTRL_scoreBar2_width            = 360 * (INFO_TrialScore2/INFO_TrialTargetCounter)

                report ('--- OUTCOME: Double Miss ---')

                goto (
                    target                      = 'End Trial'
                    when                        = ((INFO_StateCounter >= CTRL_NoStates) && timer_expired(StateDurationTimer)) || (INFO_TargetCounter >= CTRL_NoTargets)
                    )
                goto ('Dequeue Target')
            }  

            state 'End Trial' {
                //dequeue_stimulus (scoreBarBackground2)
                //dequeue_stimulus (scoreBar2)
                //dequeue_stimulus (scoreBarMask2)
                //dequeue_stimulus (scoreBarBackground)
                //dequeue_stimulus (scoreBar)
                //dequeue_stimulus (scoreBarMask)
                dequeue_stimulus (RDP)
                dequeue_stimulus (start_area)
                dequeue_stimulus (arc2)
                dequeue_stimulus (arcMask2)
                dequeue_stimulus (indicator2)   
                dequeue_stimulus (arc)
                dequeue_stimulus (arcMask)
                dequeue_stimulus (indicator)   
                dequeue_stimulus (fixationCross)
                dequeue_stimulus (fixationCross2)
                dequeue_stimulus (feedback1)
                dequeue_stimulus (feedback2)

                TRIAL_align                     = 0
                TRIAL_end                       = TRIAL_start

                start_timer (
                    timer                       = ITI_Timer
                    duration                    = CTRL_ITI_ms
                    duration_units              = ms
                    )

                update_stimulus_display ()
                report ('===== TRIAL $TRIAL_end ENDS =====')
                goto (ITI)
            }

            state ITI {
                CTRL_feedback_bar_height        = INFO_Score*(CTRL_feedback_frame_height/CTRL_NoTargets)
                CTRL_feedback2_bar_height       = INFO_Score2*(CTRL_feedback_frame_height/CTRL_NoTargets)
                CTRL_feedback_target_bar_height = INFO_TargetCounter*(CTRL_feedback_frame_height/CTRL_NoTargets)

                live_queue_stimulus (cum_rew_bar_frame)
                live_queue_stimulus (cum_rew_bar_surface)
                live_queue_stimulus (cum_rew_bar)
                live_queue_stimulus (cum_rew_bar2)
                live_queue_stimulus (cum_target_counter)
                update_stimulus_display ()   

                goto (
                    target                      = 'End paradigm'
                    when                        = INFO_TargetCounter >= CTRL_NoTargets && timer_expired(ITI_Timer)
                    )
                timer_expired (
                    target                      = 'Wait for Joystick Reset'
                    timer                       = ITI_Timer
                    )
            }
            state 'End paradigm' {
                update_stimulus_display ()
                report ('==== PLAYER_A: $INFO_HitCounter / $INFO_TargetCounter COINS COLLECTED ====')
                report ('==== PLAYER_B: $INFO_HitCounter2 / $INFO_TargetCounter COINS COLLECTED ====')
                report ('==== ENDING PARADIGM ====')
                play_sound (End_sound)
                cancelTrigger                   = false
                yield ()
            }
        }
    }
}
