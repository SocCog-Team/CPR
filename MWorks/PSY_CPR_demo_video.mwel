    y_size                                  = CTRL_indicator_size
    x_position                              = (sin((IO_joystickDirection2)*(pi/180)) * CTRL_indicator2_offset) - RDP_x
    y_position                              = (cos((IO_joystickDirection2)*(pi/180)) * CTRL_indicator2_offset) + RDP_y
    shape                                   = format("symmetric 3")
    color                                   = COL_arc2_r,COL_arc2_g,COL_arc2_b
