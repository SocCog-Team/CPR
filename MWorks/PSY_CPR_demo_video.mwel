    y_size                                  = CTRL_feedback_target_bar_height
    x_position                              = CTRL_feedback_offset_x
    y_position                              = (CTRL_feedback_target_bar_height/2) - (CTRL_feedback_frame_height/2)
    color                                   = COL_targetBar_r,COL_targetBar_g,COL_targetBar_b
    rotation                                = 0
    alpha_multiplier                        = 1
    )

