    y_size                                  = CTRL_feedback_bar_height
    x_position                              = -CTRL_feedback_offset_x
    y_position                              = (CTRL_feedback_bar_height/2) - (CTRL_feedback_frame_height/2)
    color                                   = COL_feedback_r,COL_feedback_g,COL_feedback_b
    rotation                                = 0
